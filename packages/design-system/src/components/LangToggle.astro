---
// LanguageSelect override — PT / EN toggle buttons
// Only rendered by Starlight when multiple locales are configured.
const pathname = Astro.url.pathname;

const toLocale = (newLocale: string) => {
  const replaced = pathname.replace(/^\/(pt|en)(\/|$)/, `/${newLocale}/`);
  // if no locale prefix found, fall back to /{newLocale}/
  return replaced !== pathname ? replaced : `/${newLocale}/`;
};

const isPT = pathname.startsWith('/pt');
---

<div class="lang-toggle">
  <a
    href={toLocale('pt')}
    class:list={['lang-btn', { active: isPT }]}
    aria-label="Português"
    hreflang="pt-BR"
  >PT</a>
  <a
    href={toLocale('en')}
    class:list={['lang-btn', { active: !isPT }]}
    aria-label="English"
    hreflang="en"
  >EN</a>
</div>

<style>
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-border);
    border-radius: 0.375rem;
    padding: 0.125rem;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.45rem;
    border-radius: 0.25rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
    user-select: none;
  }

  .lang-btn:hover {
    color: var(--sl-color-text);
  }

  .lang-btn.active {
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-text);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.12);
  }
</style>
